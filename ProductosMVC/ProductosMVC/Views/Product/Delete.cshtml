@model Product

@{
    ViewData["Title"] = "Delete Product";
}

<h1 class="page-title">Delete Product</h1>

<div class="warning-panel">
    <p>&#9888; Are you sure you want to delete this product? This action cannot be undone.</p>
</div>

<div class="detail-card">
    <div class="detail-row">
        <span class="detail-label">@Html.DisplayNameFor(model => model.Name):</span>
        <span class="detail-value">@Model.Name</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">@Html.DisplayNameFor(model => model.Category):</span>
        <span class="detail-value">@Model.Category</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">@Html.DisplayNameFor(model => model.BasePrice):</span>
        <span class="detail-value">@Model.BasePrice.ToString("C2")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">@Html.DisplayNameFor(model => model.Total):</span>
        <span class="detail-value">@Model.Total.ToString("C2")</span>
    </div>
</div>

<form asp-action="Delete" method="post" class="actions-bar">
    <input type="hidden" asp-for="ID" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
